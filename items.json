    "item_omega_gauntlet": {
      "name": "Omega Gauntlet of the Archmage",
      "icon": "ph:hand-fist-bold",
      "description": "An overwhelmingly complex artifact forged at the dawn of time. It acts as a devastating melee weapon, a magical conduit, and somehow contains a localized pocket dimension within its primary gemstone. It practically radiates raw, unstable power.",
      "category": "Weapon",
      "subCategory": "Artifact Melee",
      "rarity": "Artifact",
      "price": 250000,
      "weight": 8,
      "unique": true,
      "stackable": false,
