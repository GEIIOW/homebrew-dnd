      "range": "20/60",
      
      "vtt_rolls": [
        {
          "label": "Titan Punch (Melee)",
          "dice": "2d10",
          "damage_type": "Bludgeoning",
          "scaling": "STR"
        },
        {
          "label": "Energy Blast (Ranged)",
          "dice": "3d6",
          "damage_type": "Force",
          "scaling": "CHA"
        },
        {
          "label": "Overload Burst",
          "dice": "1d12",
          "damage_type": "Radiant",
          "scaling": ""
        }
      ],
      "vtt_modifiers": {
        "ac_bonus": 2,
        "strength_score_set": 24,
        "immune_fire": true,
        "immune_cold": true
      },
      
      "charges": {
        "max": 50,
        "reset": "dawn",
        "formula": "4d10 + 10" 
      },
      "spells": [
        { "spell_id": "spell_fireball", "cost": 3 },
        { "spell_id": "spell_invisibility", "cost": 2 },
        { "spell_id": "spell_eldritch_storm", "cost": 5 }
      ],
      
      "isContainer": true,
      "capacityKg": 500,
      "canTieItems": true,
      "tieCapacity": 5,
      "source": "Ancient Mythos",
      
      "errata": [
        {
          "date": "2026-05-10",
          "note": "Reduced pocket dimension capacity from 1000kg to 500kg. Players were exploiting it to carry literal dragons.",
          "previous_version": "\"capacityKg\": 1000"
        },
        {
          "date": "2025-12-01",
          "note": "Added the 'Focus' property so spellcasters can use it without dropping it.",
          "previous_version": "Did not act as a spellcasting focus."
        },
        {
          "date": "2025-08-15",
          "note": "Removed 'Finesse' property. A giant metal gauntlet shouldn't be scaling with Dexterity.",
          "previous_version": "\"properties\": [\"Finesse\", \"Versatile\", \"Thrown\"]"
        }
      ]
    },

