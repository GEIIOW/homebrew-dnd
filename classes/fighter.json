            { "label": "10 Gold Pieces", "grants": [{ "item": "gold_pieces", "quantity": 10 }] }
          ]
        },
        {
          "type": "choice",
          "choose": 1,
          "options": [
            { "label": "Ranged simple weapon and 20 munitions", "grants": [{ "item_category": "simple_ranged", "quantity": 1 }, { "item": "ammunition", "quantity": 20 }] },
            { "label": "Shield", "grants": [{ "item": "shield", "quantity": 1 }] }
          ]
        },
        {
          "type": "choice",
          "choose": 1,
          "options": [
            { "label": "2 Melee simple weapons", "grants": [{ "item_category": "simple_melee", "quantity": 2 }] },
            { "label": "Melee martial weapon (below 30gc)", "grants": [{ "item_category": "martial_melee", "quantity": 1 }] }
          ]
        },
        {
          "type": "choice",
          "choose": 1,
          "options": [
            { "label": "Dungeoneer Pack", "grants": [{ "item": "dungeoneer_pack", "quantity": 1 }] },
            { "label": "Explorer's Pack", "grants": [{ "item": "explorers_pack", "quantity": 1 }] }
          ]
        }
      ],
      "progression": [
        { "level": 1, "pb": "+2", "features": ["feat_fig_fighting_style", "feat_fig_second_wind"] },
        { "level": 2, "pb": "+2", "features": ["feat_fig_action_surge", "feat_fig_signature_maneuver"] },
        { "level": 3, "pb": "+2", "features": ["feat_fig_martial_archetype"] },
        { "level": 4, "pb": "+2", "features": ["feat_fig_asi", "feat_fig_martial_versatility"] },
        { "level": 5, "pb": "+3", "features": ["feat_fig_extra_attack"] },
        { "level": 6, "pb": "+3", "features": ["feat_fig_asi"] },
        { "level": 7, "pb": "+3", "features": ["feat_fig_subclass_feature"] },
        { "level": 8, "pb": "+3", "features": ["feat_fig_asi"] },
        { "level": 9, "pb": "+4", "features": ["feat_fig_indomitable"] },
        { "level": 10, "pb": "+4", "features": ["feat_fig_subclass_feature"] },
        { "level": 11, "pb": "+4", "features": ["feat_fig_extra_attack_2"] },
        { "level": 12, "pb": "+4", "features": ["feat_fig_asi"] },
        { "level": 13, "pb": "+5", "features": ["feat_fig_indomitable_2"] },
