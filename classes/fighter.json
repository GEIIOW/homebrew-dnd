{
  "features": {
    "feat_fig_fighting_style": {
      "name": "Fighter's Fighting Style",
      "description": "You adopt a particular style of fighting as your specialty. Choose one of the options available (Archery, Defense, Dueling, etc.). You can't take the same Fighting Style option more than once.",
      "level": 1,
      "type": "choice",
      "choose": 1,
      "options": ["feat_fig_style_archery", "feat_fig_style_defense", "feat_fig_style_dueling", "feat_fig_style_gwf", "feat_fig_style_interception", "feat_fig_style_protection", "feat_fig_style_superior", "feat_fig_style_thrown", "feat_fig_style_twf", "feat_fig_style_unarmed"]
    },
    "feat_fig_second_wind": {
      "name": "Second Wind",
      "description": "You have a limited well of stamina that you can draw on to protect yourself from harm. On your turn, you can use a bonus action to regain hit points equal to 1d10 + your fighter level. Once you use this feature, you must finish a short or long rest before you can use it again.",
      "level": 1,
      "type": "active",
      "action_type": "Bonus Action",
      "duration": "Instantaneous",
      "healing": { "dice": "1d10", "formula": "fighter_level" }
    },
    "feat_fig_action_surge": {
      "name": "Action Surge",
      "description": "You can push yourself beyond your normal limits for a moment. On your turn, you can take one additional action, except the Magic action. Once you use this feature, you can't do so again until you finish a Short or Long Rest.",
      "level": 2,
      "type": "active",
      "action_type": "Free",
      "calc": { "charges": "1" }
    },
    "feat_fig_signature_maneuver": {
      "name": "Signature Maneuver",
      "description": "Your training has had you perfect a fighting maneuver. Choose a maneuver from the maneuver list that you can use with a d6 as your superiority die. You can use this maneuver once per initiative.",
      "level": 2,
      "type": "choice",
      "choose": 1,
      "options": ["maneuver_ambush", "maneuver_brace", "maneuver_disarming", "maneuver_trip", "maneuver_parry"]
    },
    "feat_fig_extra_attack": {
      "name": "Extra Attack",
      "description": "You can attack twice, instead of once, whenever you take the Attack action on your turn. The number of attacks increases at level 11 (3) and level 20 (4).",
      "level": 5,
      "type": "passive"
    },
    "feat_fig_indomitable": {
      "name": "Indomitable",
      "description": "When you are asked to roll a saving throw, you can choose to succeed instead of rolling the save by spending an available charge of this feature.",
      "level": 9,
      "type": "active",
      "calc": { "charges": "1" }
    },
    "feat_fig_asi": {
      "name": "Ability Score Improvement",
      "description": "Increase one ability score of your choice by 2, or two scores by 1, up to a maximum of 20. Alternatively, take a feat.",
      "type": "feat_selection"
    }
  },
  "classes": [
    {
      "id": "class_fighter",
      "name": "Fighter",
      "description": "A master of martial combat, skilled with a variety of weapons and armor.",
      "image": "https://6e97130cec59272e140ab9fe07025fe2.cdn.bubble.io/cdn-cgi/image/w=768,h=768,f=auto,dpr=1,fit=contain/f1756209384242x966925665290828700/Fighter%20Jasserin-Portrait%20%282%29.png",
      "hit_die": 10,
      "subclass_level": 3,
      "hp_details": {
        "hit_dice": "1d10 per level",
        "at_first_level": "10 + CON mod",
        "at_higher_levels": "1d10 (6) + CON mod"
      },
      "proficiencies": {
        "saving_throws": ["strength", "constitution"],
        "armor": ["light_armor", "medium_armor", "heavy_armor", "shields"],
        "weapons": ["simple_weapons", "martial_weapons"],
        "tools": []
      },
      "proficiencies_desc": {
        "skills": "Choose two from Acrobatics, Animal Handling, Athletics, History, Insight, Intimidation, Perception, or Survival"
      },
      "multiclass_req": {
        "strength": 13,
        "dexterity": 13
      },
      "starting_equipment": [
        {
          "type": "choice",
          "choose": 1,
          "options": [
            { "label": "Hide Armor", "grants": [{ "item": "hide_armor", "quantity": 1 }] },
