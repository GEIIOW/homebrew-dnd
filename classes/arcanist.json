{
  "classes": {
    "class_arcanist": {
      "id": "class_arcanist",
      "name": "Arcanist",
      "source": "Faleria Core",
      "description": "A scholarly magic-user capable of manipulating the structures of reality through study and discipline.",
      "image": "https://6e97130cec59272e140ab9fe07025fe2.cdn.bubble.io/cdn-cgi/image/w=768,h=768,f=auto,dpr=1,fit=contain/f1756227934209x120279590896847920/Hero-Portrait%20%2822%29.png",
      "hit_die": 6,
      "subclass_level": 2,
      "primary_stat": "int",
      "hp_details": {
        "at_first_level": "6 + constitution",
        "at_higher_levels": "1d6 (or 4) + constitution"
      },
      "proficiencies": {
        "weapons": ["Daggers", "Darts", "Slings", "Quarterstaffs", "Light crossbows"],
        "saving_throws": ["int", "wis"],
        "skills": {
          "choose": 2,
          "options": ["Arcana", "History", "Insight", "Investigation", "Medicine", "Religion"]
        }
      },
      "starting_equipment": [
        "Spellbook",
        "Scholar's Pack or Explorer's Pack",
        "Arcane Focus or Component Pouch",
        "Quarterstaff or Dagger"
      ],
      "progression": {
        "1": { "features": ["feat_arc_spellcasting", "feat_arc_recovery", "feat_arc_scripture"], "slots": [2, 0, 0, 0, 0, 0, 0, 0, 0] },
        "2": { "features": ["feat_arc_tradition"], "slots": [3, 0, 0, 0, 0, 0, 0, 0, 0] },
        "3": { "features": [], "slots": [4, 2, 0, 0, 0, 0, 0, 0, 0] },
        "4": { "features": ["feat_arc_asi"], "slots": [4, 3, 0, 0, 0, 0, 0, 0, 0] },
        "5": { "features": [], "slots": [4, 3, 2, 0, 0, 0, 0, 0, 0] },
        "6": { "features": [], "slots": [4, 3, 3, 0, 0, 0, 0, 0, 0] },
        "7": { "features": [], "slots": [4, 3, 3, 1, 0, 0, 0, 0, 0] },
        "8": { "features": ["feat_arc_asi"], "slots": [4, 3, 3, 2, 0, 0, 0, 0, 0] },
        "9": { "features": [], "slots": [4, 3, 3, 3, 1, 0, 0, 0, 0] },
        "10": { "features": [], "slots": [4, 3, 3, 3, 2, 0, 0, 0, 0] },
        "11": { "features": [], "slots": [4, 3, 3, 3, 2, 1, 0, 0, 0] },
        "12": { "features": ["feat_arc_asi"], "slots": [4, 3, 3, 3, 2, 1, 0, 0, 0] },
        "13": { "features": [], "slots": [4, 3, 3, 3, 2, 1, 1, 0, 0] },
        "14": { "features": [], "slots": [4, 3, 3, 3, 2, 1, 1, 0, 0] },
        "15": { "features": [], "slots": [4, 3, 3, 3, 2, 1, 1, 1, 0] },
        "16": { "features": ["feat_arc_asi"], "slots": [4, 3, 3, 3, 2, 1, 1, 1, 0] },
        "17": { "features": [], "slots": [4, 3, 3, 3, 2, 1, 1, 1, 1] },
        "18": { "features": ["feat_arc_spell_mastery"], "slots": [4, 3, 3, 3, 3, 1, 1, 1, 1] },
        "19": { "features": ["feat_arc_asi"], "slots": [4, 3, 3, 3, 3, 2, 1, 1, 1] },
        "20": { "features": ["feat_arc_signature"], "slots": [4, 3, 3, 3, 3, 2, 2, 1, 1] }
      }
    }
  },
  "subclasses": {
    "sub_evocation": {
      "id": "sub_evocation",
      "class_id": "class_arcanist",
      "name": "School of Evocation",
      "description": "You focus your study on magic that creates powerful elemental effects.",
      "progression": {
        "2": ["feat_arc_evo_savant", "feat_arc_evo_sculpt"],
        "6": ["feat_arc_evo_potent"],
        "10": ["feat_arc_evo_empowered"],
        "14": ["feat_arc_evo_overchannel"]
      }
    },
    "sub_enchantment": {
      "id": "sub_enchantment",
      "class_id": "class_arcanist",
      "name": "School of Enchantment",
      "description": "Your magic focuses on influencing the minds of others."
    }
  },
  "features": {
    "feat_arc_spellcasting": {
      "id": "feat_arc_spellcasting",
      "name": "Arcanist's Spellcasting",
      "description": "As a student of arcane magic, you have a spellbook containing spells. Intelligence is your spellcasting ability.",
      "calc": {
        "Spell Save DC": "8 + pb + int",
        "Spell Attack": "pb + int"
      }
    },
    "feat_arc_recovery": {
      "id": "feat_arc_recovery",
      "name": "Arcane Recovery",
      "description": "Recover spell slots on a Short Rest equal to half your Arcanist level (rounded up).",
      "calc": {
        "Max Combined Levels": "Math.ceil(level / 2)"
      }
    },
    "feat_arc_scripture": {
      "id": "feat_arc_scripture",
      "name": "Arcane Scripture",
      "type": "choice",
      "choose": 1,
      "options": ["Acrobatics", "Athletics", "Deception", "Insight", "Intimidation", "Investigation", "Perception", "Performance", "Persuasion", "Sleight of Hand", "Stealth"],
      "description": "Expertise in Arcanian and one chosen skill.",
      "proficiencies": { "expertise": ["Arcanian"] }
    },
    "feat_arc_tradition": { "id": "feat_arc_tradition", "name": "Arcane Tradition", "description": "Choose your specialization." },
    "feat_arc_asi": { "id": "feat_arc_asi", "name": "Ability Score Improvement", "type": "feat_selection" },
    "feat_arc_spell_mastery": { "id": "feat_arc_spell_mastery", "name": "Spell Mastery", "description": "Cast a 1st and 2nd level spell without slots." },
    "feat_arc_signature": { "id": "feat_arc_signature", "name": "Signature Spells", "description": "Two 3rd level spells are always prepared." },
    "feat_arc_evo_savant": { "id": "feat_arc_evo_savant", "name": "Evocation Savant", "description": "Halved gold/time for evocation spells." },
    "feat_arc_evo_sculpt": {
      "id": "feat_arc_evo_sculpt",
      "name": "Sculpt Spells",
      "description": "Protect allies from your evocation spells.",
      "calc": { "Safe Creatures": "1 + 'Spell Level'" }
    },
    "feat_arc_evo_potent": { "id": "feat_arc_evo_potent", "name": "Potent Cantrip", "description": "Half damage on save." },
    "feat_arc_evo_empowered": {
      "id": "feat_arc_evo_empowered",
      "name": "Empowered Evocation",
      "description": "Add Intelligence to evocation damage.",
      "calc": { "Damage Bonus": "int" }
    },
    "feat_arc_evo_overchannel": {
      "id": "feat_arc_evo_overchannel",
      "name": "Overchannel",
      "description": "Maximize damage of spells (1st-5th level).",
      "calc": { "Necrotic Risk": "2d12 * 'Spell Level'" }
    }
  }
}